# LINE Developers Console > Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google AI Studio API key (Gemini)
GEMINI_API_KEY=

# Google Sheet published as CSV (File > Share > Publish to web > CSV)
SHEET_CSV_URL=

# Optional: Win's own LINE userId, to get pushed a notification when a
# customer explicitly asks to talk to a human. Get it by messaging the bot
# once as Win and reading the "[line-webhook] from userId:" line in logs.
ADMIN_LINE_USER_ID=
